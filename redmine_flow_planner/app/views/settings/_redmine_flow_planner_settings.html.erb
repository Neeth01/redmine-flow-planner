<style>
  .tabular.settings .flow-admin-settings,
  #content .tabular.settings .flow-admin-settings {
    width: 100%;
    max-width: 100%;
    margin: 0;
    padding: 0;
    overflow: visible;
  }

  .flow-admin-settings {
    --flow-admin-border: #d7dee8;
    --flow-admin-muted: #667085;
    --flow-admin-strong: #1f2937;
    --flow-admin-accent: #0f5f9c;
    display: grid;
    gap: 18px;
    width: 100%;
    max-width: 100%;
    clear: both;
  }

  .flow-admin-settings *,
  .flow-admin-settings *::before,
  .flow-admin-settings *::after {
    box-sizing: border-box;
  }

  .flow-admin-settings::after {
    content: "";
    display: block;
    clear: both;
  }

  .flow-admin-settings p,
  .flow-admin-settings div,
  .flow-admin-settings section,
  .flow-admin-settings label,
  .flow-admin-settings input,
  .flow-admin-settings select,
  .flow-admin-settings textarea,
  .flow-admin-settings small,
  .flow-admin-settings em,
  .flow-admin-settings span {
    float: none !important;
    clear: none !important;
    max-width: 100%;
  }

  .flow-admin-settings label {
    display: block;
    width: auto !important;
    margin: 0 !important;
    padding: 0 !important;
    margin-inline-start: 0 !important;
    inset-inline-start: auto !important;
    text-align: left !important;
  }

  .flow-admin-settings input,
  .flow-admin-settings select,
  .flow-admin-settings textarea {
    display: block;
  }

  .flow-admin-settings-intro,
  .flow-admin-settings-section,
  .flow-admin-settings-preview {
    border: 1px solid var(--flow-admin-border);
    border-radius: 18px;
    background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
    box-shadow: 0 8px 18px rgba(15, 23, 42, 0.05);
  }

  .flow-admin-settings-intro,
  .flow-admin-settings-preview {
    padding: 16px 18px;
  }

  .flow-admin-settings-section {
    padding: 16px 18px 18px;
    overflow: hidden;
  }

  .flow-admin-settings-title {
    margin: 0 0 4px;
    color: var(--flow-admin-strong);
    font-size: 1.05rem;
  }

  .flow-admin-settings-subtitle {
    margin: 0;
    color: var(--flow-admin-muted);
  }

  .flow-admin-settings-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px 16px;
    margin-top: 16px;
    align-items: start;
  }

  .flow-admin-settings-field {
    display: grid;
    gap: 6px;
    align-content: start;
    min-width: 0;
  }

  .flow-admin-settings-field.is-wide {
    grid-column: 1 / -1;
  }

  .flow-admin-settings-field label {
    font-weight: 700;
    color: var(--flow-admin-strong);
    line-height: 1.35;
    overflow-wrap: anywhere;
  }

  .flow-admin-settings-field small,
  .flow-admin-settings-field em {
    color: var(--flow-admin-muted);
    font-style: normal;
    line-height: 1.45;
  }

  .flow-admin-settings-field input[type="text"],
  .flow-admin-settings-field input[type="number"],
  .flow-admin-settings-field input[type="color"],
  .flow-admin-settings-field select,
  .flow-admin-settings-field textarea {
    width: 100%;
    min-height: 40px;
    padding: 8px 10px;
    border: 1px solid #c9d5e4;
    border-radius: 12px;
    background: #ffffff;
    line-height: 1.35;
  }

  .flow-admin-settings-field input[type="color"] {
    padding: 4px 6px;
  }

  .flow-admin-settings-field textarea {
    min-height: 120px;
    resize: vertical;
  }

  .flow-admin-settings-check {
    display: grid;
    grid-template-columns: 16px minmax(0, 1fr);
    align-items: start;
    gap: 12px;
    min-height: 64px;
    padding: 10px 12px;
    border: 1px solid #e1e8f0;
    border-radius: 12px;
    background: #f8fbff;
    cursor: pointer;
  }

  .flow-admin-settings-check input {
    margin: 2px 0 0;
    flex: 0 0 auto;
    width: 16px;
    height: 16px;
    min-height: 0;
  }

  .flow-admin-settings-check span {
    display: block;
    min-width: 0;
    font-weight: 700;
    line-height: 1.4;
    overflow-wrap: anywhere;
  }

  .flow-admin-settings-preview-grid {
    display: grid;
    grid-template-columns: minmax(280px, 1fr) minmax(320px, 1.2fr);
    gap: 18px;
    margin-top: 14px;
  }

  .flow-admin-preview-board,
  .flow-admin-preview-gantt {
    padding: 16px;
    border: 1px solid var(--flow-admin-border);
    border-radius: 18px;
    background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
  }

  .flow-admin-preview-board h4,
  .flow-admin-preview-gantt h4 {
    margin: 0 0 12px;
    color: var(--flow-admin-strong);
  }

  .flow-admin-preview-column {
    border: 1px solid var(--flow-admin-border);
    border-radius: var(--preview-panel-radius, 18px);
    padding: 12px;
    background: #ffffff;
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--preview-accent, #0f5f9c) 10%, white);
  }

  .flow-admin-preview-card {
    padding: 12px;
    border: 1px solid #e5edf6;
    border-radius: var(--preview-card-radius, 16px);
    background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
    box-shadow: 0 6px 14px rgba(15, 23, 42, 0.05);
    border-inline-start: 4px solid var(--preview-accent, #0f5f9c);
  }

  .flow-admin-preview-card strong,
  .flow-admin-preview-card span {
    display: block;
  }

  .flow-admin-preview-card span + span {
    margin-top: 6px;
    color: var(--flow-admin-muted);
    font-size: 0.88rem;
  }

  .flow-admin-preview-card strong {
    color: var(--preview-accent, #0f5f9c);
  }

  .flow-admin-preview-bar-wrap {
    padding: 14px;
    border: 1px solid var(--flow-admin-border);
    border-radius: var(--preview-panel-radius, 18px);
    background:
      repeating-linear-gradient(
        to right,
        transparent,
        transparent 27px,
        #edf2f7 27px,
        #edf2f7 28px
      );
  }

  .flow-admin-preview-bar {
    width: 72%;
    height: 34px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--preview-gantt-start, #155eef) 0%, var(--preview-gantt-end, #0f5f9c) 100%);
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    box-shadow: 0 8px 18px rgba(15, 95, 156, 0.18);
  }

  .flow-admin-preview-bar.is-closed {
    width: 46%;
    margin-top: 12px;
    background: linear-gradient(135deg, var(--preview-gantt-closed-start, #64748b) 0%, var(--preview-gantt-closed-end, #475569) 100%);
  }

  .flow-admin-preview-marker {
    width: 3px;
    height: 22px;
    margin-top: 12px;
    background: var(--preview-marker, #f4a261);
  }

  .flow-admin-preview-relation {
    width: 90px;
    height: 3px;
    margin-top: 12px;
    background: var(--preview-relation, #0f5f9c);
  }

  .flow-admin-preview-meta {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-top: 12px;
    color: var(--flow-admin-muted);
    font-size: 0.88rem;
  }

  @media screen and (min-width: 1400px) {
    .flow-admin-settings-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 899px) {
    .flow-admin-settings-grid {
      grid-template-columns: 1fr;
    }

    .flow-admin-settings-preview-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="flow-admin-settings" data-flow-admin-settings="true">
