      </div>

      <div class="flow-admin-settings-field">
        <label for="settings_weekend_tint_color"><%= l(:label_flow_settings_weekend_tint_color) %></label>
        <%= color_field_tag 'settings[weekend_tint_color]', settings['weekend_tint_color'], id: 'settings_weekend_tint_color' %>
      </div>
    </div>
  </section>

  <section class="flow-admin-settings-preview">
    <h3 class="flow-admin-settings-title"><%= l(:label_flow_settings_preview) %></h3>
    <p class="flow-admin-settings-subtitle"><%= l(:text_flow_settings_preview_hint) %></p>

    <div class="flow-admin-settings-preview-grid"
         data-flow-preview="true"
         style="
           --preview-accent: <%= settings['ui_accent_color'] %>;
           --preview-accent-soft: <%= settings['ui_accent_soft_color'] %>;
           --preview-panel-radius: <%= settings['panel_radius'] %>px;
           --preview-card-radius: <%= settings['card_radius'] %>px;
           --preview-gantt-start: <%= settings['gantt_bar_color_start'] %>;
           --preview-gantt-end: <%= settings['gantt_bar_color_end'] %>;
           --preview-gantt-closed-start: <%= settings['gantt_closed_bar_color_start'] %>;
           --preview-gantt-closed-end: <%= settings['gantt_closed_bar_color_end'] %>;
           --preview-relation: <%= settings['gantt_relation_color'] %>;
           --preview-marker: <%= settings['gantt_version_marker_color'] %>;
         ">
      <div class="flow-admin-preview-board">
        <h4><%= l(:label_agile_board) %></h4>
        <div class="flow-admin-preview-column">
          <div class="flow-admin-preview-card">
            <strong>#42 Livraison sprint</strong>
            <span><%= l(:label_tracker) %> : Evolution</span>
            <span><%= l(:label_flow_unassigned) %> | 60%</span>
          </div>
        </div>
      </div>

      <div class="flow-admin-preview-gantt">
        <h4><%= l(:label_planning_gantt) %></h4>
        <div class="flow-admin-preview-bar-wrap">
          <div class="flow-admin-preview-bar">60%</div>
          <div class="flow-admin-preview-bar is-closed">100%</div>
          <div class="flow-admin-preview-meta">
            <span class="flow-admin-preview-marker"></span>
            <span class="flow-admin-preview-relation"></span>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>

<script>
  (function() {
    var root = document.querySelector("[data-flow-admin-settings='true']");
    if (!root) { return; }

    var preview = root.querySelector("[data-flow-preview='true']");
    if (!preview) { return; }

    function bindColor(selector, variable) {
      var input = root.querySelector(selector);
      if (!input) { return; }
      var update = function() { preview.style.setProperty(variable, input.value); };
      input.addEventListener("input", update);
      update();
    }

    function bindNumber(selector, variable, suffix) {
      var input = root.querySelector(selector);
      if (!input) { return; }
      var update = function() { preview.style.setProperty(variable, String(input.value || "") + (suffix || "")); };
      input.addEventListener("input", update);
      update();
    }

    bindColor("#settings_ui_accent_color", "--preview-accent");
    bindColor("#settings_ui_accent_soft_color", "--preview-accent-soft");
    bindColor("#settings_gantt_bar_color_start", "--preview-gantt-start");
    bindColor("#settings_gantt_bar_color_end", "--preview-gantt-end");
    bindColor("#settings_gantt_closed_bar_color_start", "--preview-gantt-closed-start");
    bindColor("#settings_gantt_closed_bar_color_end", "--preview-gantt-closed-end");
    bindColor("#settings_gantt_relation_color", "--preview-relation");
    bindColor("#settings_gantt_version_marker_color", "--preview-marker");
    bindNumber("#settings_panel_radius", "--preview-panel-radius", "px");
    bindNumber("#settings_card_radius", "--preview-card-radius", "px");
  })();
</script>
