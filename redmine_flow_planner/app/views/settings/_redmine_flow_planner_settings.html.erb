      </div>

      <div class="flow-admin-settings-field">
        <%= hidden_field_tag 'settings[board_quick_actions]', '0' %>
        <label class="flow-admin-settings-check">
          <%= check_box_tag 'settings[board_quick_actions]', '1', settings['board_quick_actions'].to_s == '1', id: 'settings_board_quick_actions' %>
          <span><%= l(:label_flow_settings_board_quick_actions) %></span>
