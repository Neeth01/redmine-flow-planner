        <label class="flow-admin-settings-check">
          <%= check_box_tag 'settings[board_show_hours]', '1', settings['board_show_hours'].to_s == '1', id: 'settings_board_show_hours' %>
          <span><%= l(:label_flow_settings_board_hours) %></span>
