    <div class="flow-admin-settings-grid">
      <div class="flow-admin-settings-field">
        <label for="settings_board_limit"><%= l(:label_flow_board_limit) %></label>
        <%= number_field_tag 'settings[board_limit]', settings['board_limit'], id: 'settings_board_limit', min: 50, max: 1000, step: 10 %>
        <small><%= l(:text_flow_setting_board_limit_help) %></small>
      </div>

      <div class="flow-admin-settings-field">
        <label for="settings_planner_limit"><%= l(:label_flow_planner_limit) %></label>
        <%= number_field_tag 'settings[planner_limit]', settings['planner_limit'], id: 'settings_planner_limit', min: 50, max: 1000, step: 10 %>
        <small><%= l(:text_flow_setting_planner_limit_help) %></small>
      </div>

      <div class="flow-admin-settings-field">
        <label for="settings_due_soon_days"><%= l(:label_flow_due_soon_days) %></label>
        <%= number_field_tag 'settings[due_soon_days]', settings['due_soon_days'], id: 'settings_due_soon_days', min: 1, max: 90 %>
      </div>

      <div class="flow-admin-settings-field">
        <label for="settings_planner_months"><%= l(:label_flow_planner_months) %></label>
        <%= number_field_tag 'settings[planner_months]', settings['planner_months'], id: 'settings_planner_months', min: 1, max: 12 %>
      </div>

      <div class="flow-admin-settings-field">
        <label for="settings_planner_day_width"><%= l(:label_flow_planner_day_width) %></label>
        <%= number_field_tag 'settings[planner_day_width]', settings['planner_day_width'], id: 'settings_planner_day_width', min: 20, max: 48 %>
      </div>

      <div class="flow-admin-settings-field">
        <label for="settings_planner_default_scale"><%= l(:label_flow_settings_default_scale) %></label>
        <%= select_tag 'settings[planner_default_scale]',
                       options_for_select([
                         [l(:label_flow_scale_day), 'day'],
                         [l(:label_flow_scale_week), 'week'],
                         [l(:label_flow_scale_month), 'month'],
                         [l(:label_flow_scale_quarter), 'quarter']
                       ], settings['planner_default_scale']),
                       id: 'settings_planner_default_scale' %>
